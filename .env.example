# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=meetup

# Redis
REDIS_URL=redis://redis:6379/0

# Runtime
ENVIRONMENT=development
CORS_ORIGINS=[]

# Auth
AUTH_JWT_SECRET=replace-with-local-dev-secret-at-least-32-bytes
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=86400
PHONE_HASH_PEPPER=replace-with-local-dev-pepper

# OTP
OTP_DEV_ECHO_ENABLED=true
OTP_TTL_SECONDS=300
OTP_DIGITS=6
OTP_START_LIMIT_PER_PHONE=5
OTP_START_LIMIT_PER_IP=20
OTP_VERIFY_LIMIT_PER_PHONE=10
OTP_VERIFY_LIMIT_PER_IP=30

# Contacts
CONTACTS_HASH_VERSION=1
CONTACTS_MATCH_MAX_DIGESTS=500
CONTACTS_MATCH_LIMIT_PER_MINUTE=30

# Observability
METRICS_BACKEND=redis
ANALYTICS_ENABLED=true
