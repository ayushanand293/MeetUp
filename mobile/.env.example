# API
EXPO_PUBLIC_API_BASE_URL=http://your-local-ip:8000/api/v1

# Client toggles
EXPO_PUBLIC_CLIENT_ANALYTICS_ENABLED=true
EXPO_PUBLIC_CLIENT_LOCATION_FOREGROUND_ONLY=false

# Optional routing
EXPO_PUBLIC_ORS_KEY=

# Optional local mock coordinates for demos
EXPO_PUBLIC_MOCK_LAT=
EXPO_PUBLIC_MOCK_LON=

# Optional Supabase magic-link compatibility path
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key
